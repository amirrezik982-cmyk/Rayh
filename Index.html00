<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Rayhane ✨</title>

<style>
body {
  margin: 0;
  background: radial-gradient(circle, #1a0a0f, #000);
  color: white;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  overflow: hidden;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
}

#container {
  width: 90%;
  z-index: 10;
}

#text {
  font-size: 30px;
  font-weight: 300;
  opacity: 0;
  transition: opacity 1s ease-in-out;
  text-shadow: 0 0 15px rgba(255, 77, 136, 0.6);
}

.highlight {
  font-size: 55px;
  color: #ff4d88;
  text-shadow: 0 0 30px #ff4d88;
  font-weight: bold;
  animation: pulse 1.5s infinite;
}

button {
  padding: 15px 40px;
  font-size: 20px;
  border: none;
  border-radius: 50px;
  background: linear-gradient(45deg, #ff4d88, #ff85a1);
  color: white;
  cursor: pointer;
  transition: 0.4s;
  box-shadow: 0 0 20px rgba(255, 77, 136, 0.5);
}

button:hover {
  transform: scale(1.1);
  box-shadow: 0 0 40px #ff4d88;
}

/* تأثير القلوب المتطايرة */
.heart {
  position: fixed;
  top: 100vh;
  color: #ff4d88;
  font-size: 20px;
  pointer-events: none;
  animation: floatUp 4s linear infinite;
  opacity: 0.8;
}

@keyframes floatUp {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(-110vh) rotate(360deg); opacity: 0; }
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}
</style>
</head>

<body>

<div id="container">
  <button id="startBtn" onclick="start()">A message for Rayhane ❤️</button>
  <div id="text"></div>
</div>

<audio id="music" src="https://raw.githubusercontent.com/amirrezik982-cmyk/My-project-/main/HnVideoEditor_2026_04_24_212446875.mp3" loop preload="auto"></audio>

<script>
const messages = [
  "I just wanted to take a moment...",
  "To tell you how amazing you are.",
  "Rayhane...",
  "You have a truly special soul.",
  "Your kindness is inspiring...",
  "And your presence makes everything better.",
  "You deserve all the appreciation in the world.",
  "Thank you for being who you are."
];

let i = 0;

function start() {
  document.getElementById("music").play();
  document.getElementById("startBtn").style.display = "none";
  createHearts();
  show();
}

function show() {
  if (i < messages.length) {
    let t = document.getElementById("text");
    t.innerText = messages[i];
    
    // تمييز اسم ريحان
    if(messages[i] === "Rayhane...") {
        t.classList.add("highlight");
    } else {
        t.classList.remove("highlight");
    }

    t.style.opacity = 1;

    setTimeout(() => {
      t.style.opacity = 0;
      i++;
      setTimeout(show, 1000); 
    }, 2500); 

  } else {
    let t = document.getElementById("text");
    t.innerHTML = "<div class='highlight'>You are appreciated, Rayhane! ✨</div>";
    t.style.opacity = 1;
  }
}

// وظيفة إنشاء القلوب المتطايرة
function createHearts() {
  setInterval(() => {
    const heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.fontSize = (Math.random() * 20 + 20) + "px";
    heart.style.animationDuration = (Math.random() * 2 + 3) + "s";
    document.body.appendChild(heart);

    setTimeout(() => {
      heart.remove();
    }, 5000);
  }, 300);
}
</script>

</body>
</html>
